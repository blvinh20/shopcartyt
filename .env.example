# Sanity (đã có sẵn, dùng lại secret cũ trong K8s Secret shopcartyt-app-secrets)
# Tên biến thật lấy từ sanity/lib/backendClient.ts
SANITY_API_TOKEN=
SANITY_API_READ_TOKEN=

# --- Dify Knowledge Base API (dùng bởi route SERVER-SIDE app/api/sync-dify/route.ts) ---
# DIFY_API_KEY: BÍ MẬT (ghi được vào Knowledge Base). Trong cluster đi qua External Secrets (thêm
# key này vào JSON secret AWS "ecommerce-lab-dev-shopcartyt-app-secrets" -> tự xuất hiện trong K8s
# Secret nhờ dataFrom.extract). Local dev thì điền trực tiếp. Lấy từ Dify UI: Knowledge -> API.
DIFY_API_KEY=
# DIFY_API_URL: route sync chạy TRONG cluster nên trỏ Service NỘI BỘ (nhanh hơn, không ra internet).
# Đã verify thật bằng `kubectl get svc -n ai`: service proxy tên "dify" (port 80) là tương đương nội
# bộ của public origin. Local dev thì dùng https://dify.alphatrue.net/v1.
DIFY_API_URL=http://dify.ai.svc.cluster.local/v1
# Tuỳ chọn: nếu đã có sẵn 1 dataset (Knowledge Base) muốn tái sử dụng, dán id vào đây. Nếu để trống,
# route /api/sync-dify tự tạo mới 1 dataset tên "shopcartyt-products" trong LẦN GỌI ĐẦU TIÊN.
DIFY_DATASET_ID=

# --- Dify Chat Widget (đọc runtime ở server layout, xem app/(client)/layout.tsx) ---
# KHÔNG bí mật (token nằm công khai trong HTML) -> env thường, không qua Secret. Đổi tên từ
# NEXT_PUBLIC_* -> tên thường vì giờ đọc server-side + truyền prop (không còn bị inline lúc build).
# Lấy token từ Dify UI: App Chatbot/Chatflow -> Publish -> Embed on website -> copy token.
DIFY_APP_TOKEN=
# baseUrl mà BROWSER dùng để tải embed.min.js -> phải là public origin (KHÁC DIFY_API_URL nội bộ).
DIFY_WIDGET_BASE_URL=https://dify.alphatrue.net
